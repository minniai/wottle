# Local development environment template
# Copy this file to `.env.local` and fill in the values from `supabase status`

# Browser-safe values
NEXT_PUBLIC_SUPABASE_URL="http://localhost:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="anon-key-from-supabase-cli"

# Server-only credentials (never expose to client bundles)
SUPABASE_SERVICE_ROLE_KEY="service-role-key-from-supabase-cli"

# Optional helpers for scripts that connect directly to Postgres
SUPABASE_DB_PASSWORD="postgres-password"

# Playtest-specific overrides
PLAYTEST_INVITE_EXPIRY_SECONDS=30
PLAYTEST_MAX_CONCURRENT_MATCHES=20
# Optional UI toggles
NEXT_PUBLIC_ENABLE_PLAYTEST_LOBBY=""
NEXT_PUBLIC_ENABLE_PLAYTEST_MATCH=""
