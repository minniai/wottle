# Secrets file for act (local GitHub Actions runner)
# Copy this to .secrets and fill in your actual values
# .secrets is gitignored and should never be committed

# Required for act to clone actions (e.g. pnpm/action-setup, actions/checkout) from GitHub.
# Create a token at: https://github.com/settings/tokens/new
# Scopes: no scope needed for public repos; use "repo" if the workflow needs private repo access.
GITHUB_TOKEN=ghp_your_github_pat_here

# Get your Supabase access token from: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_your_token_here

