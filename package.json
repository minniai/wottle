{
  "name": "wottle",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@opentelemetry/api": "*"
      }
    },
    "allowedDeprecatedVersions": {
      "@opentelemetry/otlp-proto-exporter-base": "0.41.2",
      "glob": "7.2.3",
      "inflight": "1.0.6"
    },
    "overrides": {
      "protobufjs@<7.5.5": ">=7.5.5",
      "lodash@<4.18.0": ">=4.18.0",
      "fast-xml-parser@<5.5.7": ">=5.5.7",
      "flatted@<3.4.2": ">=3.4.2",
      "axios@<1.15.0": ">=1.15.0",
      "follow-redirects@<1.16.0": ">=1.16.0",
      "picomatch@<2.3.2": ">=2.3.2",
      "anymatch>picomatch": "^4.0.4",
      "readdirp>picomatch": "^4.0.4",
      "esbuild@<0.25.0": ">=0.25.0",
      "tmp@<0.2.4": ">=0.2.4",
      "brace-expansion@<1.1.13": "^1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "^2.0.3",
      "brace-expansion@>=4.0.0 <5.0.5": "^5.0.5",
      "brace-expansion@5.0.4": "^5.0.5"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings=0 --ext .ts,.tsx .",
    "typecheck": "tsc --pretty --noEmit",
    "test": "pnpm test:unit",
    "test:unit": "vitest --config vitest.config.ts --run --passWithNoTests",
    "test:integration": "vitest --config vitest.integration.config.ts --run --passWithNoTests",
    "guard:no-service-role": "tsx scripts/guards/no-service-role-in-client.ts",
    "supabase:migrate": "supabase migration up",
    "supabase:seed": "tsx scripts/supabase/seed.ts",
    "supabase:reset": "tsx scripts/supabase/reset.ts",
    "supabase:verify": "tsx scripts/supabase/verify.ts",
    "supabase:policies": "tsx scripts/supabase/policies/check.ts",
    "supabase:logs": "tsx scripts/supabase/log-export.ts",
    "quickstart": "./scripts/supabase/quickstart.sh",
    "quickstart:feedback": "tsx scripts/supabase/quickstart-feedback.ts",
    "perf:swap": "artillery run --output artillery-swap.json tests/perf/swap.yml && tsx scripts/perf/assert-artillery-thresholds.ts artillery-swap.json",
    "perf:lobby-presence": "SWAP_LATENCY_THRESHOLD_MS=2000 SWAP_LATENCY_MIN_SAMPLE=20 artillery run --output artillery-lobby-presence.json tests/perf/lobby-presence.yml && SWAP_LATENCY_THRESHOLD_MS=2000 SWAP_LATENCY_MIN_SAMPLE=20 tsx scripts/perf/assert-artillery-thresholds.ts artillery-lobby-presence.json",
    "perf:round-resolution": "SWAP_LATENCY_THRESHOLD_MS=200 SWAP_LATENCY_MIN_SAMPLE=20 artillery run --output artillery-round-resolution.json tests/perf/round-resolution.yml && SWAP_LATENCY_THRESHOLD_MS=200 SWAP_LATENCY_MIN_SAMPLE=20 tsx scripts/perf/assert-artillery-thresholds.ts artillery-round-resolution.json",
    "act": "./scripts/act.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.2",
    "next": "^16.2.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^1.6.1",
    "artillery": "^2.0.30",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "jsdom": "^27.4.0",
    "pg": "^8.20.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "stylelint": "^16.26.1",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1",
    "wait-on": "^7.2.0"
  }
}
