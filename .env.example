# Supabase environment variables (safe to commit)
# Populate with values from `supabase status` after running `supabase start`
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="anon-public-key"

# Service role credentials must NEVER reach the browser.
# Provide the secure key only on the server (Vercel env, server actions).
SUPABASE_SERVICE_ROLE_KEY="service-role-key"

# Optional: database password for local CLI workflows (not shipped to clients)
SUPABASE_DB_PASSWORD="postgres-password"

# Playtest-specific defaults
# Invite links expire quickly to keep lobby clean during internal playtests.
PLAYTEST_INVITE_EXPIRY_SECONDS=30
# Safety guard to limit how many parallel matches can run on a single Supabase stack.
PLAYTEST_MAX_CONCURRENT_MATCHES=20
# Optional UI toggles (leave blank to keep hidden)
NEXT_PUBLIC_ENABLE_PLAYTEST_LOBBY=""
NEXT_PUBLIC_ENABLE_PLAYTEST_MATCH=""
